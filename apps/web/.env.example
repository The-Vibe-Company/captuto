# Supabase
# Get these values from https://supabase.com/dashboard/project/[project]/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Deepgram
# Get API key from https://console.deepgram.com
DEEPGRAM_API_KEY=

# Anthropic
# Get API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Stripe
# Create a recurring Price in Stripe, then paste the price id here.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3678
